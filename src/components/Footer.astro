---
interface Props {
  currentYear?: number;
}

const { currentYear = new Date().getFullYear() } = Astro.props;

import Container from "./Container.astro";
---

<footer>
  <div class="divider layered-steps-end"></div>

  <Container>
    <div class="footer-content">
      <div class="footer-section">
        <a href="/" class="logo"> K4D3 </a>
        <p>
          A graphic designer & coder passionate about well-designed experiences
          with close attention href detail.
        </p>
      </div>

      <div class="footer-section">
        <h3>Navigation</h3>
        <ul>
          <li>
            <a href="/">Home</a>
          </li>
          <li>
            <a href="#about">About</a>
          </li>
          <li>
            <a href="/blog">Blog</a>
          </li>
          <li>
            <a href="/contact">Contact</a>
          </li>
        </ul>
      </div>

      <div class="footer-section">
        <h3>Social</h3>
        <div class="social-icons">
          <ul>
            <li>
              <a
                href="https://www.github.com/"
                target="_blank"
                rel="noopener"
                aria-label="Visit github.com (opens in a new tab)"
              >
                GitHub
              </a>
            </li>
            <li>
              <a
                href="https://www.instagram.com/"
                target="_blank"
                rel="noopener"
                aria-label="Visit instagram.com (opens in a new tab)"
              >
                Instagram
              </a>
            </li>
            <li>
              <a
                href="https://www.linkedin.com/"
                target="_blank"
                rel="noopener"
                aria-label="Visit linkedin.com (opens in a new tab)"
              >
                LinkedIn
              </a>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </Container>

  <div class="footer-bottom">
    <Container>
      <div class="footer-bottom-content">
        <p>K4D3 &copy; {currentYear}</p>
        <p>Coded with passion ❤</p>
      </div>
    </Container>
  </div>
</footer>

<style>
  /* Footer Content Grid */
  .footer-content {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr;
    gap: var(--space-lg);
    padding-block: var(--space-xl);
  }

  .logo {
    font-weight: 700;
    text-decoration: none;
    font-family: "Satoshi", sans-serif;
    font-size: var(--font-size-level-4);
  }

  /* Footer Section */
  .footer-section {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }
  .footer-section p {
    line-height: 1.6;
  }
  .footer-section h3 {
    /* font-weight: normal; */
    font-size: var(--font-size-body);
    color: var(--color-text-level-2);
    letter-spacing: unset;
  }
  .footer-section ul {
    list-style: none;
  }
  .footer-section li {
    border-bottom: 1px solid var(--color-border);
    transition: 0.3s;
  }
  .footer-section li:last-child {
    border-bottom: none;
  }
  .footer-section li a {
    /* Ensure the link covers the entire list item */
    display: block;
    padding: var(--space-xs) 0;
  }
  .footer-section li:first-child a {
    padding-top: 0;
  }
  .footer-section li:last-child a {
    padding-bottom: 0;
  }
  .footer-section li:hover {
    padding-left: 0.25rem;
  }

  .footer-bottom {
    border-top: 1px solid var(--color-border);
    padding-block: var(--space-md);
  }
  .footer-bottom-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .footer-bottom-content p {
    font-size: var(--font-size-caption);
    margin: 0;
  }

  @media (max-width: 800px) {
    .footer-content {
      display: grid;
      grid-template-columns: 1fr;
      gap: var(--space-lg);
      padding-block: var(--space-xl);
    }
    .footer-bottom-content p {
      font-size: var(--font-size-label);
    }
  }
</style>
