---
const links = [
  { href: "/", label: "Home" },
  { href: "/work", label: "Work" },
  { href: "/#about", label: "About" },
  { href: "/blog", label: "Blog" },
  { href: "/contact", label: "Contact" },
];

const pathname = Astro.url.pathname;

import Container from "../components/Container.astro";
---

<header class="site-header glass">
  <Container>
    <div class="flex-container">
      <a href="/" class="logo"> K4D3 </a>

      <button
        class="menu-toggle"
        aria-label="Toggle navigation"
        aria-expanded="false"
        aria-controls="primary-nav"
      >
        <span></span>
        <span></span>
        <span></span>
      </button>

      <nav id="primary-nav" class="nav">
        <ul>
          {
            links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class:list={{
                    active:
                      pathname === link.href ||
                      (link.href !== "/" && pathname.startsWith(link.href)),
                  }}
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </div>
  </Container>
</header>

<script>
  function initNavBar() {
    const button = document.querySelector<HTMLButtonElement>(".menu-toggle");
    const nav = document.querySelector<HTMLElement>(".nav");

    if (!button || !nav) return;

    const openMenu = () => {
      button.setAttribute("aria-expanded", "true");
      nav.classList.add("open");
    };

    const closeMenu = () => {
      button.setAttribute("aria-expanded", "false");
      nav.classList.remove("open");
    };

    button.addEventListener("click", () => {
      const isOpen = button.getAttribute("aria-expanded") === "true";

      isOpen ? closeMenu() : openMenu();
    });

    nav.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", closeMenu);
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") {
        closeMenu();
      }
    });

    window
      .matchMedia("(min-width: 768px)")
      .addEventListener("change", (event) => {
        if (event.matches) {
          closeMenu();
        }
      });
  }

  // re-init on page load to prevent astro transitions from breaking functionality
  document.addEventListener("astro:page-load", initNavBar);
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 1000;
    border-bottom: 1px solid var(--color-border);
    background-color: var(--color-bg);
    margin-bottom: var(--space-xl);
  }

  /* top line gradient */
  .site-header::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(
      to left,
      var(--color-secondary),
      var(--color-tertiary),
      var(--color-primary)
    );
  }

  .flex-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-md);
    width: 100%;
    margin: 0 auto;
    padding-block: var(--space-sm);
  }

  .glass {
    background: rgba(18, 18, 18, 0.3);
    /* background: rgba(26, 26, 26, 0.5); */
    backdrop-filter: blur(16px) saturate(180%);
    -webkit-backdrop-filter: blur(16px) saturate(180%);
  }

  .logo {
    font-weight: 700;
    text-decoration: none;
    font-family: "Satoshi", sans-serif;
  }

  .nav ul {
    display: flex;
    gap: var(--space-lg);
    list-style: none;
  }

  .nav a {
    color: var(--muted);
    text-decoration: none;
    font-weight: 500;
    transition: 0.2s;
    color: var(--color-text-level-2);
  }
  .nav a:hover {
    color: var(--color-secondary);
  }
  .nav a.active {
    color: var(--color-text-level-1);
  }

  .menu-toggle {
    display: none;
    width: 44px;
    height: 44px;
    border: none;
    background: none;
    cursor: pointer;
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
  }

  .menu-toggle span {
    display: block;
    width: 24px;
    height: 2px;
    margin: 5px auto;
    background: var(--color-text-level-1);
    transition: 0.3s;
  }

  .menu-toggle[aria-expanded="true"] span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .menu-toggle[aria-expanded="true"] span:nth-child(2) {
    opacity: 0;
  }
  .menu-toggle[aria-expanded="true"] span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  @media (max-width: 768px) {
    .menu-toggle {
      display: block;
    }

    .nav {
      --nav-height: 76px;

      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      position: fixed;
      top: var(--nav-height);
      left: 0;
      right: 0;
      height: calc(100vh - var(--nav-height)); /* fallback */
      height: calc(100dvh - var(--nav-height)); /* full height on ios */
      z-index: 10;
      background: var(--color-bg);
      border-top: 1px solid var(--color-border);
      overflow-y: auto; /* allow menu to scroll when height is compressed */

      opacity: 0;
      visibility: hidden;
      pointer-events: none;
      /* transform: translateX(100%); */
    }

    .nav ul {
      flex-direction: column;
      gap: var(--space-md);
    }

    .nav li a {
      font-size: var(--font-size-level-4);
      display: block;
    }

    .nav.open {
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
      /* transform: translateX(0); */
      transition: 0.2s ease; /* keep transition only on menu open to prevent visual bug */
    }
  }
</style>
