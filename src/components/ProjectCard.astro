---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  href: string;
  title: string;
  description: string;
  image: ImageMetadata;
  imageAlt: string;
  tag: string;
  isAboveFold?: boolean;
}

const {
  href,
  title,
  description,
  image,
  imageAlt,
  tag,
  isAboveFold = false,
} = Astro.props;
---

<a {href}>
  <article class="project-card">
    <figure>
      <Image
        src={image}
        alt={imageAlt}
        widths={[320, 640, 1024]}
        loading={isAboveFold ? "eager" : "lazy"}
      />
      <figcaption>
        <h4>{title}</h4>
        <p>{description}</p>
        <p class="tag text-highlight">{tag}</p>
      </figcaption>
    </figure>
  </article>
</a>

<!--  sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw" -->

<style>
  .project-card {
    border: 1px solid var(--color-border);
    border-radius: 1.5rem;
    overflow: hidden;
    background-color: var(--color-surface);
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  .project-card figcaption {
    display: flex;
    flex-direction: column;
    flex-grow: 1;
    gap: var(--space-sm);
    padding: var(--space-sm-2);
  }

  a .project-card {
    font-family: "Satoshi", sans-serif;
    transition: 0.2s ease-in-out;
  }

  a .project-card:hover {
    transform: scale(1.04);
    /* box-shadow: 0 0px 1rem var(--color-border); */
  }

  figcaption h4 {
    color: var(--color-text-level-1);
  }
  figcaption p {
    line-height: 1.5;
    margin: 0;
    /* font-family: "Roboto Mono", monospace; */
  }

  .tag {
    font-family: "Roboto Mono", monospace;
    font-size: var(--font-size-caption);
    margin-top: auto; /* make tags align at bottom of cards */
  }
</style>
