---
interface Props {
  size?: "sm" | "md" | "lg" | "full";
  variant?: "primary" | "secondary" | "outline";
  type?: "button" | "submit" | "reset";
  href?: string;
  class?: string;
}

const {
  size = "md",
  variant = "primary",
  type = "button",
  href,
  class: className = "",
} = Astro.props;

const classes = ["btn", `btn--${size}`, `btn--${variant}`, className];
---

{
  href ? (
    <a href={href} class:list={classes}>
      <slot />
    </a>
  ) : (
    <button type={type} class:list={classes}>
      <slot />
    </button>
  )
}

<style>
