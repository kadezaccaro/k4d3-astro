---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  href: string;
  title: string;
  description: string;
  image: ImageMetadata;
  imageAlt: string;
  tag: string;
  isAboveFold?: boolean;
}

const {
  href,
  title,
  description,
  image,
  imageAlt,
  tag,
  isAboveFold = false,
} = Astro.props;

// Import the image dynamically from the content folder
// const image = await import(`../content/projects/${projectid}/thumbnail.jpg`);
---

<a {href}>
  <article class="project-card tilt">
    <figure>
      <div class="thumbnail">
        <Image
          src={image}
          alt={imageAlt}
          widths={[320, 640, 1024]}
          loading={isAboveFold ? "eager" : "lazy"}
        />
      </div>
      <figcaption>
        <h4>{title}</h4>
        <p>{description}</p>
        <p class="tag text-highlight">{tag}</p>
      </figcaption>
    </figure>
  </article>
</a>

<!--  sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw" -->

<style>
  .project-card {
    border: 1px solid var(--color-border);
    overflow: hidden;
    /* background-color: var(--color-surface); */
    height: 100%;
    display: flex;
    flex-direction: column;
    border-radius: 2rem;
    height: 100%;
  }

  .thumbnail {
    /* border: 2px solid var(--color-border); */
    border-radius: 1rem;
    border-bottom: 1px solid var(--color-border);
    overflow: hidden;
  }

  .project-card figcaption {
    display: flex;
    flex-direction: column;
    /* flex-grow: 1; */
    gap: var(--space-sm);
    padding: var(--space-md);
  }

  a .project-card {
    font-family: "Satoshi", sans-serif;
    transition: 0.2s ease-in-out;
  }

  a .project-card:hover {
    transform: scale(1.04);
    /* box-shadow: 0 0px 1rem var(--color-border); */
  }

  figcaption {
    /* display: flex; */
  }
  figcaption h4 {
    color: var(--color-text-level-1);
  }
  figcaption p {
    line-height: 1.5;
    margin: 0;
    /* font-family: "Roboto Mono", monospace; */
  }

  .tag {
    font-family: "Roboto Mono", monospace;
    font-size: var(--font-size-caption);
    margin-top: auto;
    /* make tags align at bottom of cards */
  }
</style>
