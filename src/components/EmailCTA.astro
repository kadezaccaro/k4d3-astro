---
import Container from "./Container.astro";
import Reveal from "./Reveal.astro";
---

<div class="bg-color-primary">
  <div class="divider layered-wave"></div>
  <Container>
    <div class="container cta-flex-container">
      <h2 class="cta-lets-work">Let's work together</h2>

      <a href="/contact">
        <button>
          <!-- <Mail size={26} strokeWidth={3} /> -->
          Get in touch
        </button>
      </a>
    </div>
  </Container>
  <div class="divider layered-steps-end"></div>
</div>

<style>
  .bg-color-primary {
    background-color: var(--color-primary);
  }

  .cta-flex-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-lg);
    padding-block: var(--space-xl);
    color: var(--color-bg);
  }

  .cta-lets-work {
    font-size: var(--font-size-display-lg);
    line-height: 1;
    font-weight: 900;
    letter-spacing: -1px;
  }

  .email-button {
    font-size: var(--font-size-level-6);
    padding: 1rem 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1.25rem;
    border: 4px solid var(--color-bg);
    font-weight: 700;
  }
  .email-button:hover {
    transform: scale(1.04);
  }
  .email-button:active {
    transform: scale(0.96);
  }

  .divider {
    width: 100%;
    background-repeat: no-repeat;
    background-position: center;
    background-size: cover;
    aspect-ratio: 960/80;
    will-change: transform; /* tries to fix pixel gap between divider */
  }
  .layered-wave {
    background-image: url("../assets/dividers/layered-waves-haikei.svg");
    margin-top: var(--space-xxl);
    margin-bottom: -2px; /* tries to fix pixel gap between divider */
  }
  .layered-steps-end {
    background-image: url("../assets/dividers/layered-steps-vibrant2.svg");
    margin-top: -2px;
  }
  .simple-wave {
    background-image: url("../assets/dividers/simple-wave.svg");
    margin-bottom: -2px;
  }
  .simple-wave-end {
    background-image: url("./assets/dividers/simple-wave-end.svg");
    margin-top: -2px;
  }
</style>
