---
import Layout from "../../layouts/Layout.astro";
import Container from "../../components/Container.astro";
import { Image } from "astro:assets";
// IMPORT IMAGES
import gpStackedLogo from "../../assets/images/grand_place/GrandPlace_StackedLogo.svg";
import gpLogosCaseStudy from "../../assets/images/grand_place/GrandPlace_Logos_CaseStudy.webp";
import gpBoxKey from "../../assets/images/grand_place/gp-box-and-key.webp";
import gpLogoProcess from "../../assets/images/grand_place/logoprocess-gp.jpg";
import gpClearSpace from "../../assets/images/grand_place/gp-clearspace.webp";
import gpColorPalette from "../../assets/images/grand_place/grandplace_colorpalette.webp";
import gpBrandGuide from "../../assets/images/grand_place/BrandGuide_Presentation_Letter.webp";
import diamondHouse from "../../assets/images/grand_place/diamond-house-RD1-mockup.jpg";
import gpCardMockup from "../../assets/images/grand_place/grandplace-card-mockup4.png";
import gpLargeSign from "../../assets/images/grand_place/GrandPlace_LargeSign.svg";
import gpOpenHouse from "../../assets/images/grand_place/GrandPlace_OpenHouseSign.svg";
import gpSellersGuide from "../../assets/images/grand_place/gp-homesellersguide-mockup-v2.webp";
import gpBusCards from "../../assets/images/grand_place/gp-businesscard-rd2-option2.webp";
import gpLogomark from "../../assets/images/grand_place/GrandPlace_Logomark_Color.webp";

import PageHeader from "../../components/PageHeader.astro";
---

<Layout title="Grand Place | K4D3">
  <Container>
    <PageHeader
      title="Grand Place"
      subtitle="A new brand identity system and website for a luxury real estate team."
      tag="Branding"
      cover={gpStackedLogo}
    />
  </Container>

  <Container size="md">
    <section class="meta-strip">
      <div>
        <h3 class="subtag text-muted">Services</h3>

        <ul class="services">
          <li>Visual Strategy</li>
          <li>Branding</li>
          <li>Signage System</li>
          <li>Web Design</li>
          <li>WordPress Development</li>
        </ul>
        <!-- <p>
          Visual Strategy, Branding, Signage System, Web Design, WordPress
          Development
        </p> -->
      </div>

      <div>
        <h3 class="subtag web-url text-muted">Client</h3>
        <p>Grand Place Real Estate</p>
      </div>

      <div>
        <h3 class="subtag web-url text-muted">Website</h3>
        <div class="web-url-flex">
          <a
            class="web-url-flex"
            href="https://www.grandplacere.com/"
            target="_blank"
            rel="noreferrer"
          >
            grandplacere.com
            <!-- <SquareArrowOutUpRight /> -->
          </a>
        </div>
      </div>
    </section>
  </Container>

  <Container>
    <section class="editorial-section">
      <h2 class="case-h2">Summary</h2>

      <div>
        <p>
          Grand Place Real Estate is a growing team with a mission to fulfill
          their clients' goals with seamless and trusting service. After years
          of working under Keller Williams, it became clear to the owners that
          they needed to distinguish themselves from other teams at KW. Their
          brand was unrecognizable beyond the parent brokerage. Many realtors
          face this because they rely on templates for their brand, which
          results in everyone blending in with the competition.
        </p>
      </div>
    </section>

    <Image
      src={gpLogosCaseStudy}
      alt="Grand Place primary and secondary logos"
    />

    <section class="editorial-section">
      <h2 class="case-h2">The Solution</h2>

      <div>
        <p>
          Grand Place Real Estate is a growing team with a mission to fulfill
          their clients' goals with seamless and trusting service. After years
          of working under Keller Williams, it became clear to the owners that
          they needed to distinguish themselves from other teams at KW. Their
          brand was unrecognizable beyond the parent brokerage. Many realtors
          face this because they rely on templates for their brand, which
          results in everyone blending in with the competition.
        </p>

        <p>
          With a new identity, they wanted their brand to target a luxury market
          while still being approachable to first-home buyers. We worked
          together to create a full branding package, with collaborative review
          at each step of the process.
        </p>
        <p>
          <strong>The brand identity needed to:</strong>
        </p>
        <ul class="bullet-list">
          <li>
            Represent their professional image: modern, clean, premium,
            transparent.
          </li>
          <li>Appeal to high-end clients without feeling overly exclusive.</li>
          <li>
            Provide a polished experience that spans across all aspects of the
            business.
          </li>
        </ul>
      </div>
    </section>

    <div class="pad-around grid-auto-fit">
      <h2 class="case-h2">Brand Naming</h2>
      <div>
        <p>
          Previously operating under their last name, I worked with the
          founders, George &amp; Page, to rename their company. The old name was
          difficult to remember, and they wanted a name that embraced them as
          they expanded their team.
        </p>
        <p>
          We aimed for an ownable name that evokes both luxury and
          warmth&mdash;something they'd feel proud of&mdash;eventually landing
          on Grand Place. As an added charm, the owners love that their new
          business name happens to include their initials, G + P.
        </p>
      </div>
    </div>

    <Image src={gpBoxKey} alt="Grand Place logo embossed on a box and key" />

    <div class="pad-around grid-auto-fit">
      <h2 class="case-h2">Logo, Type &amp; Color</h2>
      <div>
        <p>
          I started with concept sketches, exploring many ideas and refining
          them into a few of the best options to present to the client.
        </p>
        <p>
          I knew I wanted to explore an option that emphasizes the founders'
          initials within the business name. I solved this with a custom 'GP'
          mark, integrated into the full logo. The paired logotype is a
          customized treatment of the brand's main typeface, Playfair Display.
          Poppins is used for body copy and other supporting text.
        </p>
        <p>
          Throughout the process, I enjoy considering different scenarios where
          the logo may used. This approach ensures optimization for various
          applications, having dedicated logos for each purpose.
        </p>
      </div>
    </div>

    <Image
      src={gpLogoProcess}
      alt="Critiquing various logo options printed out on the wall"
    />

    <Image src={gpClearSpace} alt="Grand Place minimum clear space guides" />

    <Image src={gpColorPalette} alt="Grand Place minimum clear space guides" />

    <Image
      class="pad-bottom-md"
      src={gpBrandGuide}
      alt="Grand Place brand guidelines"
    />

    <h3 class="unchosen-concepts-h3">Unchosen Concepts:</h3>
    <div class="unchosen-concepts">
      <div class="grid-auto-fit">
        <Image
          src={diamondHouse}
          alt="Unchosen concept of a diamond inside a house shining outward"
        />

        <Image
          src={gpCardMockup}
          alt="Unchosen concept of a diamond inside a house shining outward"
        />
      </div>
    </div>

    <div class="pad-around grid-auto-fit">
      <h2 class="case-h2">Signage &amp; Printed Material</h2>
      <p>
        With the industry's rules and regulations in mind, I applied the new
        branding to custom signs and other printed material.
      </p>
    </div>

    <div class="grid-auto-fit pad-bottom-md">
      <Image src={gpLargeSign} alt="Grand Place large for sale sign" />

      <Image src={gpOpenHouse} alt="Grand Place small open house sign" />
    </div>

    <Image
      src={gpSellersGuide}
      alt="Grand Place Home Seller's Guide"
      class="pad-bottom-md"
    />

    <Image src={gpBusCards} alt="Grand Place business cards" />

    <Image src={gpLogomark} alt="GP logomark with sunburst effect" />
  </Container>
</Layout>

<style>
  .editorial-section {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: var(--space-md);
    margin-bottom: var(--space-xl);
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-sm);
  }
  .editorial-section h2 {
    font-size: var(--font-size-level-3);
    font-weight: 500;
  }
  .pad-bottom {
    margin-bottom: var(--space-lg);
  }

  .meta-strip {
    display: grid;
    /* grid-template-columns: repeat(3, minmax(0, 1fr)); */
    grid-template-columns: 1.5fr 1fr 1fr;
    gap: var(--space-md);
    /* border-top: 1px solid var(--color-border); */
    /* padding-top: var(--space-sm); */
    margin-bottom: var(--space-xl);
    /* text-align: center; */
  }
  /* .meta-strip * {
    justify-content: center;
  } */

  .meta-strip p {
    color: var(--color-text-level-1);
  }

  h3 {
    text-transform: uppercase;
    font-family: "Roboto Mono";
    color: var(--color-text-level-2);
    font-size: var(--font-size-caption) !important;
    /* font-weight: 700 !important; */
  }

  .subtag {
    font-size: var(--font-size-level-6);
    margin-bottom: var(--space-sm);
    font-weight: normal;
  }

  .services {
    display: flex;
    flex-wrap: wrap;
    /* flex-direction: column; */
    gap: var(--space-xs);
    list-style-type: none;
    /* color: var(--color-quinary); */
    font-size: var(--font-size-body);
    /* font-family: "Roboto Mono", monospace; */
  }

  .services li {
    white-space: nowrap;
    background-color: var(--color-surface);
    background: linear-gradient(
      rgba(255, 255, 255, 0.1),
      rgba(255, 255, 255, 0.2)
    );
    /* border: 1px solid var(--color-border); */
    border-radius: 0.25rem;
    padding: 4px 8px;
    font-size: var(--font-size-caption);
    font-family: "Roboto Mono", monospace;
  }

  .web-url-flex {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }

  .bullet-list {
    list-style: none;
    color: var(--color-text-level-2);
  }
  .bullet-list li {
    margin: 1rem 0;
    position: relative;
    padding-left: 1.5rem;
    font-size: var(--font-size-body);
    line-height: 1.6;
  }
  .bullet-list li::before {
    content: "•";
    position: absolute;
    left: 0;
    color: var(--color-quarternary);
  }
  .bullet-list li:last-of-type {
    margin-bottom: 0;
  }

  .case-h2 {
    font-size: var(--font-size-level-2);
    line-height: 1.1;
    color: var(--color-primary);

    background-image: linear-gradient(
      90deg,
      var(--color-quinary),
      var(--color-tertiary)
    );
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .unchosen-concepts-h3 {
    display: inline-block;
    font-size: var(--font-size-level-5);
    line-height: 1;
    border: 1px solid var(--color-border);
    border-radius: 1.5rem 1.5rem 0 0;
    padding: var(--space-sm) var(--space-md);
    border-bottom: none;
  }
  .unchosen-concepts {
    padding: var(--space-md);
    border: 1px solid var(--color-border);
    border-radius: 0 1.5rem 1.5rem 1.5rem;
  }
</style>
