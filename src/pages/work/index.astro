---
import homeNetCover from "../../assets/images/temp-homelab.jpg";
import Layout from "../../layouts/Layout.astro";
import Container from "../../components/Container.astro";

import { getCollection } from "astro:content";
import ProjectCard from "../../components/ProjectCard.astro";
const projects = await getCollection("projects");
console.log("/////PROJECTS DATA/////", projects);
---

<Layout title="Projects | K4D3">
  <Container>
    <h1>Projects</h1>

    <div class="grid-auto-fit">
      {
        projects.map((project) => (
          // <ProjectCard
          //   href={`/works/${project.slug}`}
          //   title={project.title}
          //   description="Design and implementation of a secure home network using OPNsense, focusing on VLAN segmentation."
          //   image={homeNetCover}
          //   imageAlt="temp Home lab"
          //   tag="Networking"
          //   isAboveFold
          // />

          <ProjectCard
            href={`/work/${project.id}`}
            title={project.data.title}
            description={project.data.description}
            image={project.data.thumbnail}
            imageAlt="temp Home lab"
            tag="Networking"
            isAboveFold
          />
        ))
      }
    </div>
  </Container>
</Layout>

