---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Contact | K4D3">
  <header class="header-hero container-sm">
    <h1 class="case-h1">Contact</h1>

    <p>
      If you'd like to get in touch, please email{" "}
      <a href="mailto:hi@k4d3.com" class="link-highlight"> hi@k4d3.com </a>
      , or you can use the form below&mdash;I hope to hear from you soon!
    </p>
  </header>

  <main class="container-sm">
    <form action="https://formsubmit.co/hi@k4d3.com" method="POST">
      <input type="hidden" name="_captcha" value="false" />

      <input
        type="hidden"
        name="_subject"
        value="New contact form submission!"
      />

      <input
        type="hidden"
        name="_next"
        value="https://kadezaccaro.com/success"
      />

      <div class="input-container">
        <label for="name">Name</label>
        <input id="name" name="name" type="text" autocomplete="name" required />
      </div>

      <div class="input-container">
        <label for="email">Email</label>
        <input
          id="email"
          name="email"
          type="email"
          autocomplete="email"
          required
        />
      </div>

      <div class="input-container">
        <label for="message">Message</label>
        <textarea id="message" name="message" required></textarea>
      </div>

      <button type="submit" class="submit-button"> Send message </button>
    </form>
  </main>
</Layout>

