---
interface Achievement {
  title: string;
  issuer: string;
  date: string;
  icon: any;
}

interface Props {
  achievements: Achievement[];
}

const { achievements } = Astro.props;
---

<section class="cert-stack-container">
  <h3>Education & Certifications</h3>

  <div class="grid-auto-fit">
    {
      achievements.map(({ title, issuer, date, icon: Icon }) => (
        <div class="achievement-card tilt">
          <Icon />
          <h4>{title}</h4>
          <p>
            {issuer} &mdash; {date}
          </p>
        </div>
      ))
    }
  </div>
</section>

<style>
  h3 {
    margin-bottom: var(--space-md);
  }

  .achievements {
    /* --min-col-size: 400px; */
    margin-top: var(--space-md);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    /* padding-inline: var(--space-md); */
  }
  .achievements > * {
    flex: 1;
    /* min-width: 400px; */
  }

  .achievement-card {
    padding: var(--space-md);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    border: 1px solid var(--color-border);
    background-color: var(--color-surface);
    border-radius: 2rem;
    transition: 0.5s ease-in-out;
    position: relative;
    overflow: hidden;
  }
  .achievement-card p {
    line-height: 1.3;
    margin-top: auto; /* make tags align at bottom of cards */
  }

  .tilt {
    --rx: 0deg;
    --ry: 0deg;
    transform: perspective(1200px) rotateX(var(--rx)) rotateY(var(--ry));
    transform-style: preserve-3d;
    will-change: transform;
    transition:
      transform 220ms cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 220ms ease;
  }

  /* || SHINE EFFECT */

  .achievement-card::before {
    content: "";
    position: absolute;
    inset: -50%;
    background: linear-gradient(
      120deg,
      transparent 35%,
      rgb(255 255 255 / 0.05) 50%,
      transparent 65%
    );
    transform: translateX(-150%) rotate(20deg);
    pointer-events: none;
  }

  .achievement-card:hover::before {
    animation: shine 2.5s ease-in-out infinite;
  }

  @keyframes shine {
    to {
      transform: translateX(150%) rotate(20deg);
    }
  }
</style>

<script type="module">
  import "../scripts/tilt.ts";
</script>
