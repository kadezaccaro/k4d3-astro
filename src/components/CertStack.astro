---
import BadgeIcon from "./icons/BadgeIcon.astro";
import GradIcon from "./icons/GradIcon.astro";
---

<section class="cert-stack-container">
  <header class="cert-header-section">
    <h3>Education & Certifications</h3>
  </header>

  <div class="achievements">
    <div class="achievement-card tilt">
      <GradIcon class="cert-icon" />
      <h4>Associate's Degree in Cybersecurity</h4>
      <p>Lanier Technical College &mdash; December 2026</p>
    </div>

    <div class="achievement-card tilt">
      <BadgeIcon />
      <h4>CompTIA A+ Certification</h4>
      <p>CompTIA &mdash; May 2026</p>
    </div>

    <div class="achievement-card tilt">
      <BadgeIcon />
      <h4>CompTIA A+ Certification</h4>
      <p>CompTIA &mdash; May 2026</p>
    </div>

    <!-- <div class="achievement-card">
      <h4>CompTIA Security+ Certification</h4>
      <p>CompTIA &mdash; June 2026</p>
    </div>

    <div class="achievement-card">
      <h4>CompTIA Network+ Certification</h4>
      <p>CompTIA &mdash; July 2026</p>
    </div> -->
  </div>
</section>

<style>
  /* .cert-icon {
    font-size: var(--font-size-display-sm);
  } */

  .cert-header-section {
    padding-inline: var(--space-md);
  }

  .achievements {
    /* --min-col-size: 400px; */
    margin-top: var(--space-md);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    /* padding-inline: var(--space-md); */
  }
  .achievements > * {
    flex: 1;
    /* min-width: 400px; */
  }

  .achievement-card {
    padding: var(--space-md);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    border: 1px solid var(--color-border);
    background-color: var(--color-surface);
    border-radius: 2rem;
    transition: 0.5s ease-in-out;
    position: relative;
    overflow: hidden;
  }
  .achievement-card p {
    line-height: 1.3;
    margin-top: auto; /* make tags align at bottom of cards */
  }

  .tilt {
    --rx: 0deg;
    --ry: 0deg;
    transform: perspective(1200px) rotateX(var(--rx)) rotateY(var(--ry));
    transform-style: preserve-3d;
    will-change: transform;
    transition:
      transform 220ms cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 220ms ease;
  }

  /* || SHINE EFFECT */

  .achievement-card::before {
    content: "";
    position: absolute;
    inset: -50%;
    background: linear-gradient(
      120deg,
      transparent 35%,
      rgb(255 255 255 / 0.05) 50%,
      transparent 65%
    );
    transform: translateX(-150%) rotate(20deg);
    pointer-events: none;
  }

  .achievement-card:hover::before {
    animation: shine 2.5s ease-in-out infinite;
  }

  @keyframes shine {
    to {
      transform: translateX(150%) rotate(20deg);
    }
  }
</style>

<script type="module">
  import "../scripts/tilt.ts";
</script>
