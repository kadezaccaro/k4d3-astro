---
import { Image } from "astro:assets";

interface Props {
  tag?: string;
  title: string;
  subtitle?: string;
  background?: ImageMetadata;
  cover?: ImageMetadata;
  coverAlt?: string;
}

const { tag, title, subtitle, background, cover, coverAlt } = Astro.props;
---

<header class="case-hero">
  {
    background && (
      <img id="background" src={background.src} fetchpriority="high" />
    )
  }

  {tag && <span class="case-hero__tag">{tag}</span>}

  <h1>{title}</h1>

  {subtitle && <h2 class="case-hero__subtitle">{subtitle}</h2>}

  {
    cover && (
      <div class="case-hero__image">
        <Image
          src={cover}
          alt={coverAlt ?? title}
          loading="eager"
          fetchpriority="high"
          class="case-cover"
        />
      </div>
    )
  }
</header>

<style>
  .case-hero {
    margin-bottom: var(--space-lg);
    position: relative;
  }
  #background {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -10;
    filter: blur(100px);
    /* opacity: 0.5; */
  }
  .case-hero__tag {
    border: 1px solid var(--color-border);
    padding: 0.4rem 0.8rem;
    border-radius: 0.5rem;
    margin-bottom: var(--space-md);
    text-transform: uppercase;
    font-family: "Roboto Mono";
    display: inline-block;
    /* background-color: var(--color-surface); */
    color: var(--color-text-level-2);
  }
  .case-hero h1 {
    font-weight: 800;
    line-height: 0.8;
    letter-spacing: -0.05em;
    margin-bottom: var(--space-md);
  }
  .case-hero__subtitle {
    font-size: var(--font-size-level-5);
    font-weight: normal;
    color: var(--color-quinary);
    letter-spacing: unset;
    margin-bottom: var(--space-lg-2);
  }

  .case-hero :global(img) {
    /* border: 1px solid var(--color-border); */
    border-radius: 2rem;
  }
</style>
