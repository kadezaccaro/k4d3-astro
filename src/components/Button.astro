  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    border: none;
    cursor: pointer;
    text-decoration: none;
    font-family: "Roboto Mono", monospace;
    font-size: var(--font-size-body);
    font-weight: 700;
    text-transform: uppercase;
    transition: 0.3s;
  }

  /* Size Variants */
  .btn--sm {
    padding: 0.5rem 1rem;
    font-size: 0.875rem;
  }

  .btn--md {
    padding: var(--space-sm) var(--space-sm-2);
    font-size: var(--font-size-level-6);
    border-radius: 1rem;
  }

  .btn--lg {
    padding: 1rem 2rem;
    font-size: var(--font-size-level-5);
  }

  .btn--full {
    width: 100%;
    padding: var(--space-xs) var(--space-sm-2);
  }

  /* Style Variants */
  .btn--primary {
    background: none;
    color: var(--color-text-level-1);
    border: 2px solid var(--color-primary);
  }

  .btn--primary:hover {
    border-color: var(--color-text-level-1);
    /* transform: translateY(-2px); */
    /* box-shadow: 0 4px 12px rgba(59, 130, 246, 0.3); */
  }
  .btn--primary:hover {
    transform: scale(1.04);
  }
  .btn--primary:active {
    transform: scale(0.96);
  }

  .btn--secondary {
    background-color: var(--color-secondary);
    color: var(--color-bg);
    border-radius: 0.5rem;
  }

  .btn--secondary:hover {
    background: var(--color-text-level-1);
  }

  .btn--outline {
    background-color: transparent;
    border: 2px solid #3b82f6;
    color: #3b82f6;
  }

  .btn--outline:hover {
    background-color: #eff6ff;
  }
</style>
